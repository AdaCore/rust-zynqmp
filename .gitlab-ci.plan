def build():
    anod_install("rust")
    anod_install("rust", target="aarch64-elf")
    anod_build("rust-multi", target="aarch64-elf")
    anod_build("rust-zynqmp-bsp", target="aarch64-elf")

def test():
    anod_install("rust")
    anod_install("rust", target="aarch64-elf")
    anod_build("rust-multi", target="aarch64-elf")
    anod_test("rust-zynqmp-bsp", target="aarch64-elf")
